{
  "name": "documents-frontend",
  "productName": "documents-frontend",
  "version": "1.0.0",
  "description": "Document management system frontend",
  "main": ".vite/build/main.js",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts,.tsx .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:skip-reset": "SKIP_RESET=1 playwright test",
    "postinstall": "electron-rebuild -w smart-whisper || echo 'electron-rebuild failed for smart-whisper; local voice engine disabled until tools are available'"
  },
